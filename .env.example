VITE_APP_URL=https://example.com
BETTER_AUTH_URL=https://example.com
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
BETTER_AUTH_TRUSTED_ORIGINS=https://example.com
BATWARA_AUTH_EMAIL_FROM="Batwara <auth@example.com>"
BATWARA_AUTH_LOG_EMAIL_EVENTS=false
BATWARA_ALLOW_CONSOLE_AUTH_EMAIL=false
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_INTERACTIVE_BACKGROUND=true
VITE_ENABLE_HERO_SCENE=true
VITE_ENABLE_HERO_SCENE_ON_MOBILE=false
